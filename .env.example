APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CENTRAL_DOMAINS=localhost,127.0.0.1

APP_LOCALE=en
APP_LOCALE_DEFAULT=en
APP_SUPPORTED_LOCALES=en,es
APP_LOCALE_COOKIE=locale
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_SSO_WRITE_HOST=${REDIS_HOST}
REDIS_SSO_WRITE_PASSWORD=${REDIS_PASSWORD}
REDIS_SSO_WRITE_PORT=${REDIS_PORT}
REDIS_SSO_WRITE_DB=0
REDIS_SSO_WRITE_ROLE=primary

SSO_MODE=backchannel
SSO_ISSUER=${APP_URL}
SSO_AUDIENCE=tenant-sso
SSO_ASSERTION_TTL_SECONDS=30
SSO_BACKCHANNEL_CODE_TTL_SECONDS=30
SSO_TOKEN_STORE=array
SSO_REDIS_WRITE_CONNECTION=sso_write
SSO_REDIS_WRITE_ROLE=primary
SSO_S2S_HEADER=X-S2S-Key
SSO_S2S_CLIENTS={}
SSO_JWT_ALGORITHM=RS256
SSO_JWT_TYP=JWT
SSO_JWT_KID=local-kid-1
SSO_JWT_ALLOWED_KIDS=local-kid-1
SSO_JWT_CLOCK_SKEW_SECONDS=60
SSO_JWT_PRIVATE_KEY=
SSO_JWT_PUBLIC_KEY=
SSO_JWT_PUBLIC_KEYS={}
SSO_CLAIMS_VERSION=v1
SSO_CLAIMS_CACHE_STORE=array
SSO_CLAIMS_QUOTA_STORE=array
SSO_CLAIMS_CACHE_TTL_SECONDS=60
SSO_CLAIMS_RATE_LIMIT_PER_MINUTE=60
SSO_CLAIMS_DAILY_QUOTA=1000
SSO_CLAIMS_WEEKLY_QUOTA=5000
SSO_CLAIMS_ALARM_HIT_RATIO_THRESHOLD=0.98
SSO_CLAIMS_ALARM_MISS_SPIKE_THRESHOLD=100
SSO_TRUSTED_PLATFORM_DOMAINS=localhost,127.0.0.1
SSO_ENABLE_HSTS_PRELOAD=false
SSO_HSTS_MAX_AGE=63072000

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
